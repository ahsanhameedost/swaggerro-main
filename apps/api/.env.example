API_HOST=0.0.0.0
API_PORT=3001

NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soaswag?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=CHANGE_ME_SUPER_SECRET_32_CHARS_MIN
JWT_EXPIRES_IN=7d

COOKIE_NAME=soaswag_at
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET_32_CHARS_MIN
COOKIE_SECURE=false

CORS_ORIGIN=http://localhost:3000

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@soaswag.com
ADMIN_EMAIL=admin@soaswag.local

# Storage driver: "local" (writes to apps/api/uploads, no AWS needed) or "s3".
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads
API_PUBLIC_URL=http://localhost:3001/api

# Only required when STORAGE_DRIVER=s3
AWS_REGION=
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=